{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "rootDir": "src"
  },
  "include": ["src/**/*.js"]
}